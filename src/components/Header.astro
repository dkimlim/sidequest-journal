---
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { withBase } from '../lib/url';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<h1 class="site-title"><a href={withBase('/')}>{SITE_TITLE}</a></h1>
	<p class="site-subtitle">{SITE_DESCRIPTION}</p>
	<nav class="site-nav">
		<HeaderLink href={withBase('/')}>Home</HeaderLink>
		<HeaderLink href={withBase('/blog')}>Archive</HeaderLink>
		<HeaderLink href={withBase('/about')}>About</HeaderLink>
	</nav>
</header>
